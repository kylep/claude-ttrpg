# Copy this file to .env and fill in the keys you have. .env is gitignored.

# Required when IMAGE_MODEL=openai (the default). Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required when IMAGE_MODEL=gemini or gemini-2.5-flash. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Which image provider/model tools/imagegen.py uses by default: openai | gemini | gemini-2.5-flash
IMAGE_MODEL=openai

# Refuse to generate more than this many images in a single tools/imagegen.py invocation
IMAGEGEN_MAX_PER_RUN=1

# Refuse to generate if cumulative estimated spend (see .imagegen-ledger.json) would exceed this, in USD
IMAGEGEN_SPEND_CAP_USD=5.00
